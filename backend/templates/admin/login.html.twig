{# templates/admin/login.html.twig #}
<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Connexion - Espace Modérateur</title>
		<link rel="icon" type="image/svg+xml" href="{{ asset('assets/favicon_Kontakt.png') }}"/>

		<style>
			/* Reset basique pour avoir le même rendu sur tous les navigateurs */
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
				font-family: system-ui, -apple-system, sans-serif;
			}

			body {
				background-color: #1a2238;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
			}

			.login-card {
				background-color: #25304F;
				padding: 2rem;
				border-radius: 0.75rem;
				box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
				width: 100%;
				max-width: 400px;
				border: 1px solid rgba(137, 124, 233, 0.2);
			}

			.header {
				text-align: center;
				margin-bottom: 2rem;
			}

			.header h1 {
				font-size: 1.875rem;
				font-weight: 700;
				color: #897ce9;
			}

			.header p {
				color: #e6e6ea;
				margin-top: 0.5rem;
				font-size: 0.95rem;
			}

			.error-message {
				background-color: rgba(255, 118, 117, 0.15);
				border: 1px solid #ff7675;
				color: #ff9999;
				padding: 0.75rem 1rem;
				border-radius: 0.375rem;
				margin-bottom: 1.5rem;
				font-size: 0.875rem;
			}

			.form-group {
				margin-bottom: 1.5rem;
			}

			.form-group label {
				display: block;
				font-size: 0.875rem;
				font-weight: 500;
				color: #e6e6ea;
				margin-bottom: 0.5rem;
			}

			.form-group input {
				display: block;
				width: 100%;
				padding: 0.5rem 1rem;
				background-color: #1a2238;
				border: 1px solid rgba(137, 124, 233, 0.3);
				border-radius: 0.5rem;
				font-size: 1rem;
				color: #e6e6ea;
				transition: border-color 0.2s, box-shadow 0.2s;
			}

			.form-group input::placeholder {
				color: #707070;
			}

			.form-group input:focus {
				outline: none;
				border-color: #897ce9;
				box-shadow: 0 0 0 3px rgba(137, 124, 233, 0.2);
			}

			.submit-btn {
				width: 100%;
				padding: 0.625rem 1rem;
				border: none;
				border-radius: 0.5rem;
				font-size: 0.875rem;
				font-weight: 600;
				color: #ffffff;
				background-color: #897ce9;
				cursor: pointer;
				transition: background-color 0.2s;
			}

			.submit-btn:hover {
				background-color: #7a6ad1;
			}

			.footer-link {
				margin-top: 1.5rem;
				text-align: center;
			}

			.footer-link a {
				font-size: 0.875rem;
				color: #897ce9;
				text-decoration: none;
				transition: color 0.2s;
			}

			.footer-link a:hover {
				color: #7a6ad1;
			}
		</style>
	</head>
	<body>

		<img src="{{ asset('assets/Logo.png') }}" alt="Logo de KONTAKT" style="width: 300px; margin: 5rem 0;"/>

		<div class="login-card">
			<div class="header">
				<h1>BackOffice Administrateur</h1>
				<p>Veuillez vous identifier</p>
			</div>

			{% if error %}
				<div class="error-message">
					{{ error.messageKey|trans(error.messageData, 'security') }}
				</div>
			{% endif %}

			<form action="{{ action }}" method="post">

				<div class="form-group">
					<label for="username">Nom d'utilisateur</label>
					<input type="text" id="username" name="_username" value="{{ last_username }}" autocomplete="current-username" required autofocus>
				</div>

				<div class="form-group">
					<label for="password">Mot de passe</label>
					<input type="password" id="password" name="_password" autocomplete="current-password" required>
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				<button type="submit" class="submit-btn">
					Se connecter
				</button>

			</form>

			<div class="footer-link">
				<a href="http://localhost:8090">← Retour au site public</a>
			</div>

		</div>

	</body>
</html>
