<IfModule mod_rewrite.c>
    RewriteEngine On

    # Définit la base de réécriture pour le dossier public
    RewriteBase /~lochis1/SAE401/backend/public/

    # Redirige toutes les requêtes vers index.php si ce n'est pas un fichier ou un répertoire existant
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<IfModule mod_php.c>
    php_value upload_max_filesize 100M
    php_value post_max_size 100M
    php_value memory_limit 256M
</IfModule>